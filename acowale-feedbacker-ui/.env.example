# ─────────────────────────────────────────────────────────────────────────────
# Acowale Feedbacker UI — Environment Variables
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the real .env file — it is git-ignored.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the NestJS API (no trailing slash)
# Development: http://localhost:3000/api/v1
# Production:  https://your-api-domain.com/api/v1
VITE_API_URL=http://localhost:3000/api/v1
