# ─────────────────────────────────────────────────────────────────────────────
# Acowale Feedbacker API — Environment Variables
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the real .env file — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Frontend origin allowed for CORS (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# Secret used to sign cookies (min 32 random characters)
COOKIE_SECRET=change-me-to-a-random-32-char-secret

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/acowale-feedbacker
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/acowale-feedbacker
MONGODB_URI=mongodb://localhost:27017/acowale-feedbacker

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a strong random secret (min 32 chars)
JWT_SECRET=change-me-to-a-strong-random-jwt-secret
JWT_EXPIRES_IN=24h

# ─── Rate Limiter ─────────────────────────────────────────────────────────────
# TTL in milliseconds (default: 60000 = 1 minute)
THROTTLER_TTL=60000
# Max requests per TTL window per IP
THROTTLER_LIMIT=10

# ─── Logging ──────────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug | verbose
LOG_LEVEL=info
